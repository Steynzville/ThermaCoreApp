# Production Environment Variables for Netlify
# These should be configured in Netlify's Environment Variables settings
# Dashboard > Site Settings > Environment Variables

# Backend API Base URL
# This is the URL of the deployed backend API
# Default: https://thermacoreapp.onrender.com (hardcoded in authService.js)
VITE_API_BASE_URL=https://thermacoreapp.onrender.com
VITE_API_URL=https://thermacoreapp.onrender.com

# Note: If VITE_API_BASE_URL is not set, the app will default to:
# https://thermacoreapp.onrender.com
# This is hardcoded in src/services/authService.js as a fallback
